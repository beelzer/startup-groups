<?xml version="1.0" encoding="UTF-8"?>
<!--
    Burn bundle that wraps Velopack's Setup.exe and replaces vpk's lean
    progress-bar UX with our 5-screen managed BA (StartupGroups.Installer.UI).
    The chained ExePackage runs Setup.exe silently under the hood; the BA
    draws the user-facing UI.

    Architectural note: the chained package is Velopack's Setup.exe, NOT the
    raw MSI. An MSI-based bundle install lands at %LocalAppData%\Programs\
    Startup Groups\ with no Velopack runtime files (Update.exe, current\,
    packages\), which means UpdateManager.IsInstalled returns false and
    auto-update silently breaks. Wrapping Setup.exe lays down the full
    Velopack runtime AND gives us the Mica BA UX.

    Velopack Setup.exe CLI (verified against velopack/velopack setup.rs):
    -  `silent`    : suppress all dialogs, suppress post-install launch
    -  `installto` : override install dir
    -  no uninstall flag exists. Uninstall happens via Update.exe
       (`%LocalAppData%\StartupGroups\Update.exe` with the silent +
       uninstall flags) driven by Velopack's own ARP entry. We mark
       the chained package Permanent="yes" so Burn never tries to call
       Setup.exe with uninstall args (which would fail). The BA's
       Uninstall flow invokes Update.exe directly before engine.Apply
       runs.

    Bundle UpgradeCode lives in Directory.Build.props (AppBundleUpgradeCode);
    distinct from the MSI's UpgradeCode and never changes.

    Note on syntax: WixDotNetCoreBootstrapperApplicationHost (the WiX 4
    in-process .NET host) is deprecated in WiX 5. The new OOP model treats
    the BA as a normal subprocess — just point SourceFile at the EXE.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

    <Bundle Name="$(var.ProductName)"
            Manufacturer="$(var.CompanyName)"
            Version="$(var.ProductVersion)"
            UpgradeCode="$(var.BundleUpgradeCode)"
            HelpUrl="$(var.SupportUrl)"
            AboutUrl="$(var.AboutUrl)"
            IconSourceFile="$(var.IconPath)"
            DisableModify="yes">

        <BootstrapperApplication SourceFile="$(var.MainExePath)">
            <!-- The <Payloads Include="..." /> globbing element ships in WiX
                 6+. Our pinned 5.0.2 toolchain doesn't have it, so the build
                 script enumerates the publish folder and emits an explicit
                 <PayloadGroup Id="InstallerUiPayloads"> into a side file. -->
            <PayloadGroupRef Id="InstallerUiPayloads" />
        </BootstrapperApplication>

        <Chain>
            <ExePackage Id="StartupGroupsVelopack"
                        SourceFile="$(var.VelopackSetupPath)"
                        PerMachine="no"
                        Permanent="yes"
                        Vital="yes"
                        Compressed="yes"
                        InstallArguments="--silent" />
        </Chain>
    </Bundle>
</Wix>
