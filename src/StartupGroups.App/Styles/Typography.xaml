<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!--
        Font family with glyph-coverage fallback chain:
            Segoe UI Variable   - Latin, Cyrillic, Greek (primary on Windows 11)
            Segoe UI            - Latin/Cyrillic fallback for older Windows
            Yu Gothic UI        - Japanese
            Meiryo UI           - Japanese fallback
            Microsoft YaHei UI  - Simplified Chinese
            Malgun Gothic       - Korean
            Nirmala UI          - Devanagari (Hindi), other Indic scripts
            Tahoma              - Arabic, Hebrew, Thai
    -->
    <FontFamily x:Key="AppFontFamily">Segoe UI Variable, Segoe UI, Yu Gothic UI, Meiryo UI, Microsoft YaHei UI, Malgun Gothic, Nirmala UI, Tahoma</FontFamily>

    <system:Double x:Key="FontSizeDisplay">28</system:Double>
    <system:Double x:Key="FontSizeH1">28</system:Double>
    <system:Double x:Key="FontSizeH2">20</system:Double>
    <system:Double x:Key="FontSizeSubtitle">24</system:Double>
    <system:Double x:Key="FontSizeH3">15</system:Double>
    <system:Double x:Key="FontSizeLarge">16</system:Double>
    <system:Double x:Key="FontSizeMedium">14</system:Double>
    <system:Double x:Key="FontSizeBody">13</system:Double>
    <system:Double x:Key="FontSizeMuted">12</system:Double>
    <system:Double x:Key="FontSizeCaption">11</system:Double>
    <system:Double x:Key="FontSizeMicro">10</system:Double>

    <system:Double x:Key="AppBodyFontSize">13</system:Double>

    <Style x:Key="AppH1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeH1}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="AppH2" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeH2}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="AppH3" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeH3}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
    </Style>

    <Style x:Key="AppMuted" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMuted}" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
    </Style>

</ResourceDictionary>
