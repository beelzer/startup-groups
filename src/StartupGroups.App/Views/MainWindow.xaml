<ui:FluentWindow x:Class="StartupGroups.App.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:StartupGroups.App.ViewModels"
                 xmlns:conv="clr-namespace:StartupGroups.App.Converters"
                 xmlns:ctrl="clr-namespace:StartupGroups.App.Controls"
                 xmlns:loc="clr-namespace:StartupGroups.App.Localization"
                 xmlns:res="clr-namespace:StartupGroups.App.Resources"
                 Title="{loc:Translate Window_Main_Title}"
                 Width="{StaticResource WindowMainWidth}"
                 Height="{StaticResource WindowMainHeight}"
                 MinWidth="{StaticResource WindowMainMinWidth}"
                 MinHeight="{StaticResource WindowMainMinHeight}"
                 FlowDirection="{loc:FlowDirection}"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:BoolToVisibilityConverter x:Key="NotBoolToVisibility" Invert="True" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
        <conv:NullToVisibilityConverter x:Key="NotNullToVisibility" Invert="True" />
        <conv:StringToSymbolConverter x:Key="StringToSymbol" />
        <conv:RunningStateBrushConverter x:Key="RunningBrush" />
        <conv:RunningStateTextConverter x:Key="RunningText" />
        <conv:RunningStateAppearanceConverter x:Key="PlayAppearance" RunningAppearance="Secondary" StoppedAppearance="Primary" />
        <conv:RunningStateAppearanceConverter x:Key="StopAppearance" RunningAppearance="Primary" StoppedAppearance="Secondary" />
        <conv:EnumMatchConverter x:Key="EnumMatch" />
        <conv:FractionToWidthConverter x:Key="FractionToWidth" />
        <conv:FractionToLeftMarginConverter x:Key="FractionToLeftMargin" />

        <!-- Segmented view-mode toggle button -->
        <Style x:Key="ViewModeToggleButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusSm}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Reusable sidebar nav button template -->
        <Style x:Key="SidebarNavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusSm}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Wrap in AdornerDecorator so drag ghosts (and any future adorners) have a guaranteed layer;
         FluentWindow's chrome template doesn't include one. -->
    <AdornerDecorator x:Name="RootAdornerHost">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title-bar row: TitleBar covers both columns; a column-aligned overlay renders the group
             heading in the content column area so it lines up with the apps list below. -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource SidebarWidthGridLength}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        Panel.ZIndex="1"
                        IsHitTestVisible="False"
                        Visibility="{Binding IsGroupsViewWithSelection, Converter={StaticResource BoolToVisibility}}">
                <ctrl:GroupIconView Icon="{Binding SelectedGroup.Icon}"
                                    IconSize="{StaticResource IconSizeLg}"
                                    IconForeground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0" />
                <TextBlock Text="{Binding SelectedGroup.Name, FallbackValue={x:Null}}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            </StackPanel>

        <ui:TitleBar Grid.Column="0" Grid.ColumnSpan="2">
            <ui:TitleBar.Icon>
                <ui:ImageIcon x:Name="TitleBarIcon" />
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <!-- WPF-UI's TitleBar.Header replaces the Title text, so we render the app name here
                     alongside the admin status pill. -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{loc:Translate Window_Main_Title}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <Button Margin="12,0,0,0"
                            Padding="8,2"
                            BorderThickness="0"
                            Cursor="Hand"
                            Focusable="False"
                            VerticalAlignment="Center"
                            Command="{Binding NavigateToAdminSettingsCommand}"
                            Visibility="{Binding ShouldShowAdminPill, Converter={StaticResource BoolToVisibility}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="PillBorder"
                                        CornerRadius="{StaticResource RadiusSm}"
                                        Padding="{TemplateBinding Padding}"
                                        Background="{DynamicResource SystemFillColorCautionBackgroundBrush}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon x:Name="PillIcon"
                                                       Symbol="ShieldError24"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SystemFillColorCautionBrush}" />
                                        <TextBlock x:Name="PillText"
                                                   Text="{loc:Translate Admin_Pill_Recommended}"
                                                   Margin="6,0,0,0"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SystemFillColorCautionBrush}" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="PillBorder" Property="Opacity" Value="0.85" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsRunningAsAdmin}" Value="True">
                                        <Setter TargetName="PillBorder" Property="Background" Value="{DynamicResource SystemFillColorSuccessBackgroundBrush}" />
                                        <Setter TargetName="PillIcon" Property="Symbol" Value="ShieldCheckmark24" />
                                        <Setter TargetName="PillIcon" Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                        <Setter TargetName="PillText" Property="Text" Value="{x:Static res:Strings.Admin_Pill_Active}" />
                                        <Setter TargetName="PillText" Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </ui:TitleBar.Header>
            <ui:TitleBar.TrailingContent>
                <!-- Contextual group controls: only visible when a group is selected in the Groups view. -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            Visibility="{Binding IsGroupsViewWithSelection, Converter={StaticResource BoolToVisibility}}">
                    <ui:Button Appearance="{Binding SelectedGroup.AllRunning, Converter={StaticResource PlayAppearance}}"
                               Icon="{ui:SymbolIcon Play24}"
                               Content="{loc:Translate Action_LaunchAll}"
                               Command="{Binding LaunchGroupCommand}"
                               CommandParameter="{Binding SelectedGroup}"
                               IsEnabled="{Binding SelectedGroup.CanLaunchAll}"
                               Margin="0,0,6,0" />
                    <ui:Button Appearance="{Binding SelectedGroup.AllRunning, Converter={StaticResource StopAppearance}}"
                               Icon="{ui:SymbolIcon Stop24}"
                               Content="{loc:Translate Action_StopAll}"
                               Command="{Binding StopGroupCommand}"
                               CommandParameter="{Binding SelectedGroup}"
                               IsEnabled="{Binding SelectedGroup.CanStopAll}"
                               Margin="0,0,6,0" />
                    <ui:Button Icon="{ui:SymbolIcon Edit24}"
                               ToolTip="{loc:Translate Action_RenameGroup}"
                               Command="{Binding EditGroupCommand}"
                               CommandParameter="{Binding SelectedGroup}"
                               Margin="0,0,6,0" />
                    <ui:Button Icon="{ui:SymbolIcon Delete24}"
                               ToolTip="{loc:Translate Action_RemoveGroup}"
                               Command="{Binding RemoveGroupCommand}"
                               CommandParameter="{Binding SelectedGroup}" />
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource SidebarWidthGridLength}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Grid x:Name="SidebarRoot" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Rectangle x:Name="SidebarIndicator"
                           Width="{StaticResource SidebarIndicatorWidth}"
                           Height="{StaticResource SidebarIndicatorHeight}"
                           RadiusX="2" RadiusY="2"
                           Fill="{DynamicResource AccentFillColorDefaultBrush}"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Margin="16,0,0,0"
                           Opacity="0"
                           IsHitTestVisible="False"
                           Panel.ZIndex="10">
                    <Rectangle.RenderTransform>
                        <TranslateTransform x:Name="SidebarIndicatorTransform" />
                    </Rectangle.RenderTransform>
                </Rectangle>

                <Grid Grid.Row="0" Margin="{StaticResource SidebarPadding}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button x:Name="WindowsStartupButton"
                            Grid.Row="0"
                            Style="{StaticResource SidebarNavButton}"
                            Command="{Binding ShowStartupViewCommand}">
                        <Button.Background>
                            <SolidColorBrush Color="Transparent" />
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusSm}" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsStartupView}" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0"
                                           Symbol="WindowApps24"
                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                           FontSize="{StaticResource FontSizeH2}"
                                           VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{loc:Translate Sidebar_WindowsStartup_Label}"
                                       Margin="14,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </Grid>
                    </Button>

                    <Button x:Name="BenchmarksButton"
                            Grid.Row="1"
                            Padding="12,10"
                            BorderThickness="0"
                            HorizontalContentAlignment="Stretch"
                            Margin="0,4,0,0"
                            Command="{Binding ShowBenchmarksViewCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusSm}" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsBenchmarksView}" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0"
                                           Symbol="Timer24"
                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                           FontSize="{StaticResource FontSizeH2}"
                                           VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{loc:Translate Sidebar_Benchmarks_Label}"
                                       Margin="14,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </Grid>
                    </Button>

                    <Button x:Name="SettingsButton"
                            Grid.Row="2"
                            Padding="12,10"
                            BorderThickness="0"
                            HorizontalContentAlignment="Stretch"
                            Margin="0,4,0,0"
                            Command="{Binding ShowSettingsViewCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusSm}" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsSettingsView}" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0"
                                           Symbol="Settings24"
                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                           FontSize="{StaticResource FontSizeH2}"
                                           VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{loc:Translate Sidebar_Settings_Label}"
                                       Margin="14,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </Grid>
                    </Button>

                    <Border Grid.Row="3" Background="{DynamicResource CardStrokeColorDefaultBrush}" Height="1" Margin="8,12,8,8" />

                    <Grid Grid.Row="4" Margin="8,4,8,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{loc:Translate Sidebar_Groups_Heading}"
                                   FontSize="{StaticResource FontSizeH2}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" />
                        <ui:Button Grid.Column="1"
                                   Appearance="Primary"
                                   Icon="{ui:SymbolIcon Add24}"
                                   Content="{loc:Translate Action_New}"
                                   Command="{Binding AddGroupCommand}" />
                    </Grid>

                    <ListView Grid.Row="5"
                              x:Name="GroupsList"
                              Background="Transparent"
                              BorderThickness="0"
                              ItemsSource="{Binding Groups}"
                              SelectedItem="{Binding SelectedGroup}"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Standard"
                              VirtualizingStackPanel.ScrollUnit="Item"
                              HorizontalContentAlignment="Stretch"
                              AllowDrop="True"
                              PreviewMouseLeftButtonDown="GroupsList_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="GroupsList_PreviewMouseMove"
                              DragOver="GroupsList_DragOver"
                              Drop="GroupsList_Drop">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="12,10" />
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Grid>
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusSm}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter />
                                                </Border>
                                                <!-- Drop indicators sit at the item's outer edges (outside padding), so the bar lands in the 4px gap between items. Only one of these is ever visible across the whole list during a drag. -->
                                                <Rectangle x:Name="GroupDropAbove"
                                                           VerticalAlignment="Top"
                                                           Height="2"
                                                           Margin="4,0,4,0"
                                                           Fill="{DynamicResource AccentFillColorDefaultBrush}"
                                                           Visibility="Collapsed"
                                                           IsHitTestVisible="False" />
                                                <Rectangle x:Name="GroupDropBelow"
                                                           VerticalAlignment="Bottom"
                                                           Height="2"
                                                           Margin="4,0,4,0"
                                                           Fill="{DynamicResource AccentFillColorDefaultBrush}"
                                                           Visibility="Collapsed"
                                                           IsHitTestVisible="False" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:GroupViewModel}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!-- Fixed icon column so every row's name text starts at the same x. -->
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ctrl:GroupIconView Grid.Column="0"
                                                        Icon="{Binding Icon}"
                                                        IconSize="{StaticResource IconSizeMd}"
                                                        IconForeground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                               Text="{Binding AppsCountText}"
                                               Style="{StaticResource AppMuted}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>

            <!-- Detail pane: Groups view -->
            <Grid Grid.Column="1" Margin="{StaticResource ContentPagePadding}"
                  Visibility="{Binding IsGroupsView, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{loc:Translate Apps_Heading}" Style="{StaticResource AppH3}" VerticalAlignment="Center" />

                    <Border Grid.Column="1"
                            CornerRadius="{StaticResource RadiusSm}"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            Padding="2"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Style="{StaticResource ViewModeToggleButton}"
                                         GroupName="AppsViewMode"
                                         ToolTip="{loc:Translate ViewMode_Compact}"
                                         IsChecked="{Binding AppsViewMode, Converter={StaticResource EnumMatch}, ConverterParameter=Compact}">
                                <ui:SymbolIcon Symbol="AppsList24" FontSize="{StaticResource IconSizeSm}" />
                            </RadioButton>
                            <RadioButton Style="{StaticResource ViewModeToggleButton}"
                                         GroupName="AppsViewMode"
                                         ToolTip="{loc:Translate ViewMode_Detailed}"
                                         IsChecked="{Binding AppsViewMode, Converter={StaticResource EnumMatch}, ConverterParameter=Detailed}">
                                <ui:SymbolIcon Symbol="AppsListDetail24" FontSize="{StaticResource IconSizeSm}" />
                            </RadioButton>
                        </StackPanel>
                    </Border>

                    <ui:Button Grid.Column="2"
                               Appearance="Primary"
                               Icon="{ui:SymbolIcon Add24}"
                               Content="{loc:Translate Action_AddApp}"
                               MinHeight="{StaticResource ButtonMinHeight}"
                               Command="{Binding AddAppCommand}" />
                </Grid>

                <Border Grid.Row="3"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMd}">
                    <Grid>
                        <!-- Empty state: no apps in this group -->
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400"
                                    Visibility="{Binding SelectedGroup.IsEmpty, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
                            <Border Width="56" Height="56"
                                    CornerRadius="{StaticResource RadiusMd}"
                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,14">
                                <ui:SymbolIcon Symbol="AppsAddIn24" FontSize="28"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{loc:Translate Empty_NoAppsInGroup_Title}"
                                       Style="{StaticResource AppH3}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{loc:Translate Empty_NoAppsInGroup_Hint}"
                                       Style="{StaticResource AppMuted}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                    <!-- Detailed view (rich rows, default) -->
                    <ItemsControl ItemsSource="{Binding SelectedGroup.Apps}"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Standard"
                                  VirtualizingStackPanel.ScrollUnit="Pixel"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  AllowDrop="True"
                                  DragOver="AppsContainer_DragOver"
                                  Drop="AppsContainer_Drop">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding SelectedGroup.HasApps}" Value="True" />
                                            <Condition Binding="{Binding DataContext.AppsViewMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="Detailed" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer CanContentScroll="True"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Focusable="False">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AppEntryViewModel}">
                                <Border x:Name="RowRoot"
                                        Tag="{Binding}"
                                        AllowDrop="True"
                                        PreviewMouseLeftButtonDown="Row_PreviewMouseLeftButtonDown"
                                        PreviewMouseMove="Row_PreviewMouseMove"
                                        DragOver="Row_DragOver"
                                        DragLeave="Row_DragLeave"
                                        Drop="Row_Drop"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Background="Transparent"
                                        Padding="0"
                                        Height="{StaticResource ListRowHeight}">
                                    <Grid ClipToBounds="False">
                                        <Rectangle x:Name="DropAbove" Height="2" VerticalAlignment="Top" HorizontalAlignment="Stretch"
                                                   Margin="8,0,8,0"
                                                   Fill="{DynamicResource AccentFillColorDefaultBrush}" Visibility="Collapsed" />
                                        <Rectangle x:Name="DropBelow" Height="2" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                                   Margin="8,0,8,0"
                                                   Fill="{DynamicResource AccentFillColorDefaultBrush}" Visibility="Collapsed" />
                                        <Grid Margin="{StaticResource ListRowPadding}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Ellipse Grid.Column="0" Width="10" Height="10"
                                                 VerticalAlignment="Center" Margin="0,0,14,0"
                                                 Fill="{Binding IsRunning, Converter={StaticResource RunningBrush}}" />

                                        <Grid Grid.Column="1"
                                              Width="{StaticResource IconSizeXl}" Height="{StaticResource IconSizeXl}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,16,0">
                                            <ui:SymbolIcon Symbol="Apps24" FontSize="{StaticResource IconSizeLg}"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           Visibility="{Binding Icon, Converter={StaticResource NullToVisibility}}" />
                                            <Image Source="{Binding Icon}"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Visibility="{Binding Icon, Converter={StaticResource NotNullToVisibility}}" />
                                        </Grid>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="{StaticResource FontSizeMedium}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}" CornerRadius="{StaticResource RadiusXs}" Padding="6,1">
                                                    <TextBlock Text="{Binding Kind}" Style="{StaticResource AppMuted}" />
                                                </Border>
                                                <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                        CornerRadius="{StaticResource RadiusXs}"
                                                        Padding="6,1"
                                                        Margin="6,0,0,0"
                                                        ToolTip="{Binding LastBenchmarkTooltip}"
                                                        Visibility="{Binding HasBenchmark, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="{Binding LastDurationDisplay}" Style="{StaticResource AppMuted}" />
                                                </Border>
                                                <TextBlock Text="{Binding IsRunning, Converter={StaticResource RunningText}}"
                                                           Style="{StaticResource AppMuted}" Margin="8,0,0,0" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3"
                                                    VerticalAlignment="Center"
                                                    Margin="16,0,16,0">
                                            <TextBlock Style="{StaticResource AppMuted}"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Text>
                                                    <PriorityBinding>
                                                        <Binding Path="Path" FallbackValue="" />
                                                        <Binding Path="Service" FallbackValue="" />
                                                    </PriorityBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Args}"
                                                       Style="{StaticResource AppMuted}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       FontFamily="Consolas"
                                                       Opacity="0.7"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0"
                                                       Visibility="{Binding Args, Converter={StaticResource NotNullToVisibility}}">
                                                <TextBlock.ToolTip>
                                                    <ToolTip MaxWidth="1400">
                                                        <TextBlock Text="{Binding Args}" TextWrapping="NoWrap" />
                                                    </ToolTip>
                                                </TextBlock.ToolTip>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:Button Appearance="{Binding IsRunning, Converter={StaticResource PlayAppearance}}"
                                                       Icon="{ui:SymbolIcon Play24}"
                                                       ToolTip="{loc:Translate Action_Launch}"
                                                       IsEnabled="{Binding IsStopped}"
                                                       Command="{Binding DataContext.LaunchAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       CommandParameter="{Binding}"
                                                       Margin="0,0,6,0" />
                                            <ui:Button Appearance="{Binding IsRunning, Converter={StaticResource StopAppearance}}"
                                                       Icon="{ui:SymbolIcon Stop24}"
                                                       ToolTip="{loc:Translate Action_Stop}"
                                                       IsEnabled="{Binding IsRunning}"
                                                       Command="{Binding DataContext.StopAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       CommandParameter="{Binding}"
                                                       Margin="0,0,6,0" />
                                            <ui:Button Icon="{ui:SymbolIcon Edit24}"
                                                       ToolTip="{loc:Translate Action_Edit}"
                                                       Command="{Binding DataContext.EditAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       CommandParameter="{Binding}"
                                                       Margin="0,0,6,0" />
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}"
                                                       ToolTip="{loc:Translate Action_Remove}"
                                                       Command="{Binding DataContext.RemoveAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Compact view (table rows) -->
                    <ItemsControl ItemsSource="{Binding SelectedGroup.Apps}"
                                  Grid.IsSharedSizeScope="True"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  AllowDrop="True"
                                  DragOver="AppsContainer_DragOver"
                                  Drop="AppsContainer_Drop">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding SelectedGroup.HasApps}" Value="True" />
                                            <Condition Binding="{Binding DataContext.AppsViewMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="Compact" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer CanContentScroll="True"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Focusable="False">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AppEntryViewModel}">
                                <Border x:Name="RowRoot"
                                        Tag="{Binding}"
                                        AllowDrop="True"
                                        PreviewMouseLeftButtonDown="Row_PreviewMouseLeftButtonDown"
                                        PreviewMouseMove="Row_PreviewMouseMove"
                                        DragOver="Row_DragOver"
                                        DragLeave="Row_DragLeave"
                                        Drop="Row_Drop"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Background="Transparent"
                                        Padding="0">
                                    <Grid ClipToBounds="False">
                                        <Rectangle x:Name="DropAbove" Height="2" VerticalAlignment="Top" HorizontalAlignment="Stretch"
                                                   Margin="8,0,8,0"
                                                   Fill="{DynamicResource AccentFillColorDefaultBrush}" Visibility="Collapsed" />
                                        <Rectangle x:Name="DropBelow" Height="2" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                                   Margin="8,0,8,0"
                                                   Fill="{DynamicResource AccentFillColorDefaultBrush}" Visibility="Collapsed" />
                                        <Grid Margin="16,6,6,6" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="AppName" />
                                            <ColumnDefinition Width="Auto" SharedSizeGroup="AppKind" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Ellipse Grid.Column="0" Width="8" Height="8"
                                                 VerticalAlignment="Center" Margin="0,0,12,0"
                                                 Fill="{Binding IsRunning, Converter={StaticResource RunningBrush}}" />

                                        <Grid Grid.Column="1"
                                              Width="18" Height="18"
                                              VerticalAlignment="Center"
                                              Margin="0,0,10,0">
                                            <ui:SymbolIcon Symbol="Apps24" FontSize="16"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           Visibility="{Binding Icon, Converter={StaticResource NullToVisibility}}" />
                                            <Image Source="{Binding Icon}"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   Visibility="{Binding Icon, Converter={StaticResource NotNullToVisibility}}" />
                                        </Grid>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Name}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,12,0"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                                        <StackPanel Grid.Column="3"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Kind}"
                                                       Style="{StaticResource AppMuted}" />
                                            <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                    CornerRadius="{StaticResource RadiusXs}"
                                                    Padding="6,1"
                                                    Margin="8,0,0,0"
                                                    ToolTip="{Binding LastBenchmarkTooltip}"
                                                    Visibility="{Binding HasBenchmark, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding LastDurationDisplay}" Style="{StaticResource AppMuted}" />
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Grid.Column="4"
                                                   Style="{StaticResource AppMuted}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,12,0">
                                            <TextBlock.Text>
                                                <PriorityBinding>
                                                    <Binding Path="Path" FallbackValue="" />
                                                    <Binding Path="Service" FallbackValue="" />
                                                </PriorityBinding>
                                            </TextBlock.Text>
                                            <TextBlock.ToolTip>
                                                <ToolTip MaxWidth="1400">
                                                    <TextBlock TextWrapping="NoWrap">
                                                        <TextBlock.Text>
                                                            <PriorityBinding>
                                                                <Binding Path="Path" FallbackValue="" />
                                                                <Binding Path="Service" FallbackValue="" />
                                                            </PriorityBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </ToolTip>
                                            </TextBlock.ToolTip>
                                        </TextBlock>

                                        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                            <ui:Button Appearance="{Binding IsRunning, Converter={StaticResource PlayAppearance}}"
                                                       Icon="{ui:SymbolIcon Play24}"
                                                       ToolTip="{loc:Translate Action_Launch}"
                                                       IsEnabled="{Binding IsStopped}"
                                                       Command="{Binding DataContext.LaunchAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       CommandParameter="{Binding}"
                                                       Margin="0,0,4,0" />
                                            <ui:Button Appearance="{Binding IsRunning, Converter={StaticResource StopAppearance}}"
                                                       Icon="{ui:SymbolIcon Stop24}"
                                                       ToolTip="{loc:Translate Action_Stop}"
                                                       IsEnabled="{Binding IsRunning}"
                                                       Command="{Binding DataContext.StopAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       CommandParameter="{Binding}"
                                                       Margin="0,0,4,0" />
                                            <ui:Button Icon="{ui:SymbolIcon Edit24}"
                                                       ToolTip="{loc:Translate Action_Edit}"
                                                       Command="{Binding DataContext.EditAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       CommandParameter="{Binding}"
                                                       Margin="0,0,4,0" />
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}"
                                                       ToolTip="{loc:Translate Action_Remove}"
                                                       Command="{Binding DataContext.RemoveAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                       CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <!-- Detail pane: Windows Startup view -->
            <Grid Grid.Column="1" Margin="{StaticResource ContentPagePadding}"
                  Grid.IsSharedSizeScope="True"
                  Visibility="{Binding DataContext.IsStartupView, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"
                  DataContext="{Binding WindowsStartup}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="1" Margin="0,4,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{loc:Translate Sidebar_WindowsStartup_Label}" Style="{StaticResource AppH2}" />
                        <TextBlock Text="{loc:Translate WinStartup_Description}" Style="{StaticResource AppMuted}" Margin="0,2,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:Button Appearance="Primary"
                                   Icon="{ui:SymbolIcon Add24}"
                                   Content="{loc:Translate Action_AddApp}"
                                   Command="{Binding AddEntryCommand}"
                                   MinHeight="{StaticResource ButtonMinHeight}"
                                   Margin="0,0,8,0" />
                        <ui:Button Icon="{ui:SymbolIcon ArrowClockwise24}"
                                   ToolTip="{loc:Translate Action_Refresh}"
                                   MinHeight="{StaticResource ButtonMinHeight}"
                                   MinWidth="{StaticResource ButtonMinWidth}"
                                   Command="{Binding ReloadListCommand}" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2" Padding="16,0,6,0" Margin="0,0,0,4">
                    <Grid Height="36">
                        <Grid.Resources>
                            <Style x:Key="SortHeaderButton" TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="HorizontalContentAlignment" Value="Left" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="Height" Value="32" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="HorizontalAlignment" Value="Left" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusSm}" Padding="8,0">
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Grid.Resources>
                        <!-- Column widths & SharedSizeGroups mirror the row DataTemplate below.
                             Change them together: everything that is Auto syncs via IsSharedSizeScope. -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="SG_Enabled" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="SG_Icon" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="SG_Source" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="SG_Actions" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Style="{StaticResource SortHeaderButton}" Margin="-8,0,12,0"
                                Command="{Binding SortByCommand}" CommandParameter="Enabled">
                            <TextBlock Style="{StaticResource AppMuted}">
                                <Run Text="{loc:Translate WinStartup_Column_Enabled}" /><Run Text="{Binding EnabledSortIndicator, Mode=OneWay}" />
                            </TextBlock>
                        </Button>

                        <!-- Icon column header is intentionally blank; width syncs with the row icon cell. -->

                        <Button Grid.Column="2" Style="{StaticResource SortHeaderButton}" Margin="-8,0,12,0"
                                Command="{Binding SortByCommand}" CommandParameter="Name">
                            <TextBlock Style="{StaticResource AppMuted}">
                                <Run Text="{loc:Translate WinStartup_Column_Name}" /><Run Text="{Binding NameSortIndicator, Mode=OneWay}" />
                            </TextBlock>
                        </Button>

                        <Button Grid.Column="3" Style="{StaticResource SortHeaderButton}" Margin="-8,0,12,0"
                                Command="{Binding SortByCommand}" CommandParameter="Command">
                            <TextBlock Style="{StaticResource AppMuted}">
                                <Run Text="{loc:Translate WinStartup_Column_Command}" /><Run Text="{Binding CommandSortIndicator, Mode=OneWay}" />
                            </TextBlock>
                        </Button>

                        <Button Grid.Column="4" Style="{StaticResource SortHeaderButton}" Margin="-8,0,8,0"
                                Command="{Binding SortByCommand}" CommandParameter="Source">
                            <TextBlock Style="{StaticResource AppMuted}">
                                <Run Text="{loc:Translate WinStartup_Column_Source}" /><Run Text="{Binding SourceSortIndicator, Mode=OneWay}" />
                            </TextBlock>
                        </Button>

                        <TextBlock Grid.Column="5" Text="{loc:Translate Apps_Column_Actions}" Style="{StaticResource AppMuted}" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Grid.Row="3"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMd}">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}">
                            <Border Width="56" Height="56"
                                    CornerRadius="{StaticResource RadiusMd}"
                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,14">
                                <ui:SymbolIcon Symbol="Rocket24" FontSize="28"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{loc:Translate Empty_NoStartupItems_Title}"
                                       Style="{StaticResource AppH3}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="{loc:Translate Empty_NoStartupItems_Hint}"
                                       Style="{StaticResource AppMuted}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                    <ItemsControl ItemsSource="{Binding EntriesView}"
                                  Visibility="{Binding HasEntries, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Standard"
                                  VirtualizingStackPanel.ScrollUnit="Pixel"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer CanContentScroll="True"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Focusable="False">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:WindowsStartupEntryViewModel}">
                                <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16,6,6,6">
                                        <Grid>
                                            <!-- Column widths synced to the header above via SharedSizeGroup.
                                                 Header lives in the same Grid.IsSharedSizeScope="True" container. -->
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="SG_Enabled" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="SG_Icon" />
                                                <ColumnDefinition Width="220" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="SG_Source" />
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="SG_Actions" />
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Margin="0,0,12,0">
                                                <ui:ToggleSwitch x:Name="StartupToggle"
                                                                 IsChecked="{Binding Enabled}"
                                                                 IsEnabled="{Binding CanModify}"
                                                                 ToolTip="{Binding AdminRequiredTooltip}"
                                                                 ToolTipService.ShowOnDisabled="True" />
                                                <!-- When the row needs admin, the entire toggle area becomes a button that
                                                     jumps to Settings. Width/Height pin to the toggle so the shield is
                                                     actually centered on it, not on the widened header-sized cell. -->
                                                <Button Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="0"
                                                        Cursor="Hand"
                                                        ToolTip="{Binding AdminRequiredTooltip}"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Width="{Binding ActualWidth, ElementName=StartupToggle}"
                                                        Height="{Binding ActualHeight, ElementName=StartupToggle}"
                                                        Visibility="{Binding RequiresAdmin, Converter={StaticResource BoolToVisibility}}"
                                                        Command="{Binding DataContext.NavigateToAdminSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <ui:SymbolIcon Symbol="ShieldError24"
                                                                   FontSize="24"
                                                                   Foreground="{DynamicResource SystemFillColorCautionBrush}" />
                                                </Button>
                                            </Grid>

                                            <Grid Grid.Column="1"
                                                  Width="18" Height="18"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,10,0">
                                                <ui:SymbolIcon Symbol="Apps24" FontSize="16"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Visibility="{Binding Icon, Converter={StaticResource NullToVisibility}}" />
                                                <Image Source="{Binding Icon}"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality"
                                                       Visibility="{Binding Icon, Converter={StaticResource NotNullToVisibility}}" />
                                            </Grid>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Name}"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,12,0"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Command}"
                                                       Style="{StaticResource AppMuted}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,12,0">
                                                <TextBlock.ToolTip>
                                                    <ToolTip MaxWidth="1400">
                                                        <TextBlock Text="{Binding Command}" TextWrapping="NoWrap" />
                                                    </ToolTip>
                                                </TextBlock.ToolTip>
                                            </TextBlock>

                                            <Border Grid.Column="4"
                                                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                    CornerRadius="{StaticResource RadiusXs}"
                                                    Padding="6,1"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Source}" Style="{StaticResource AppMuted}" />
                                            </Border>

                                            <StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <ui:Button Icon="{ui:SymbolIcon Edit24}"
                                                           ToolTip="{Binding OpenActionTooltip}"
                                                           Visibility="{Binding IsRegistryEntry, Converter={StaticResource BoolToVisibility}}"
                                                           Command="{Binding DataContext.OpenLocationCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           CommandParameter="{Binding}"
                                                           Margin="0,0,4,0" />
                                                <ui:Button Icon="{ui:SymbolIcon FolderOpen24}"
                                                           ToolTip="{Binding OpenActionTooltip}"
                                                           Visibility="{Binding IsRegistryEntry, Converter={StaticResource NotBoolToVisibility}}"
                                                           Command="{Binding DataContext.OpenLocationCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           CommandParameter="{Binding}"
                                                           Margin="0,0,4,0" />
                                                <ui:Button Icon="{ui:SymbolIcon Delete24}"
                                                           ToolTip="{Binding RemoveTooltip}"
                                                           ToolTipService.ShowOnDisabled="True"
                                                           IsEnabled="{Binding CanModify}"
                                                           Command="{Binding DataContext.RemoveEntryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                           CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <!-- Detail pane: Benchmarks view -->
            <ScrollViewer Grid.Column="1"
                          Margin="{StaticResource ContentPagePadding}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding IsBenchmarksView, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Margin="0,4,8,24" DataContext="{Binding Benchmarks}">
                    <TextBlock Text="{loc:Translate Benchmarks_Heading}" Style="{StaticResource AppH1}" />
                    <TextBlock Text="{loc:Translate Benchmarks_Subtitle}"
                               Style="{StaticResource AppMuted}" Margin="0,4,0,0" />

                    <!-- Summary cards -->
                    <ItemsControl Margin="0,20,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" Columns="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="{StaticResource RadiusMd}" Padding="16" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="{loc:Translate Benchmarks_Metric_TotalLaunches}" Style="{StaticResource AppMuted}" FontSize="10" />
                                <TextBlock Text="{Binding TotalCount}"
                                           FontSize="{StaticResource FontSizeH1}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="{StaticResource RadiusMd}" Padding="16" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBlock Text="{loc:Translate Benchmarks_Metric_Ready}" Style="{StaticResource AppMuted}" FontSize="10" />
                                <TextBlock Text="{Binding ReadyCount}"
                                           FontSize="{StaticResource FontSizeH1}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="{StaticResource RadiusMd}" Padding="16" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBlock Text="{loc:Translate Benchmarks_Metric_TimedOut}" Style="{StaticResource AppMuted}" FontSize="10" />
                                <TextBlock Text="{Binding TimedOutCount}"
                                           FontSize="{StaticResource FontSizeH1}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="{StaticResource RadiusMd}" Padding="16" Margin="4,0,4,0">
                            <StackPanel>
                                <TextBlock Text="{loc:Translate Benchmarks_Metric_ColdMedian}" Style="{StaticResource AppMuted}" FontSize="10" />
                                <TextBlock Text="{Binding ColdMedianDisplay}"
                                           FontSize="{StaticResource FontSizeH1}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="{StaticResource RadiusMd}" Padding="16" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{loc:Translate Benchmarks_Metric_WarmMedian}" Style="{StaticResource AppMuted}" FontSize="10" />
                                <TextBlock Text="{Binding WarmMedianDisplay}"
                                           FontSize="{StaticResource FontSizeH1}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </ItemsControl>

                    <!-- Per-app summaries -->
                    <TextBlock Text="{loc:Translate Benchmarks_Section_PerApp}" Style="{StaticResource AppH2}" Margin="0,24,0,8" />
                    <ItemsControl ItemsSource="{Binding PerApp}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AppBenchmarkSummaryViewModel}">
                                <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="{StaticResource RadiusSm}"
                                        Padding="14,10"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Image Grid.Column="0"
                                               Source="{Binding Icon}"
                                               Width="{StaticResource IconSizeMd}"
                                               Height="{StaticResource IconSizeMd}"
                                               Stretch="Uniform"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"
                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding AppName}" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                <Border Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                                        CornerRadius="{StaticResource RadiusXs}"
                                                        Padding="6,1"
                                                        Margin="8,0,0,0"
                                                        ToolTip="{Binding RegressionText}"
                                                        Visibility="{Binding IsRegression, Converter={StaticResource BoolToVisibility}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="Warning24" FontSize="12"
                                                                       Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                                                       VerticalAlignment="Center" />
                                                        <TextBlock Text="{Binding RegressionText}"
                                                                   FontSize="{StaticResource FontSizeCaption}"
                                                                   Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                                                   Margin="4,0,0,0" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Style="{StaticResource AppMuted}">
                                                <Run Text="{Binding TotalCount, Mode=OneWay}" />
                                                <Run Text=" launches · " />
                                                <Run Text="{Binding ColdCount, Mode=OneWay}" />
                                                <Run Text=" cold" />
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0" MinWidth="80">
                                            <TextBlock Text="{loc:Translate Benchmarks_Metric_Last}" Style="{StaticResource AppMuted}" FontSize="10" />
                                            <TextBlock Text="{Binding LastDurationDisplay}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="12,0" MinWidth="80">
                                            <TextBlock Text="{loc:Translate Benchmarks_Metric_Median}" Style="{StaticResource AppMuted}" FontSize="10" />
                                            <TextBlock Text="{Binding MedianDisplay}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="12,0" MinWidth="80">
                                            <TextBlock Text="{loc:Translate Benchmarks_Metric_ColdMed}" Style="{StaticResource AppMuted}" FontSize="10" />
                                            <TextBlock Text="{Binding ColdMedianDisplay}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="5" VerticalAlignment="Center" Margin="12,0,0,0" MinWidth="80">
                                            <TextBlock Text="{loc:Translate Benchmarks_Metric_WarmMed}" Style="{StaticResource AppMuted}" FontSize="10" />
                                            <TextBlock Text="{Binding WarmMedianDisplay}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Suggested order (dependency inference) -->
                    <TextBlock Text="{loc:Translate Benchmarks_Section_SuggestedOrder}" Style="{StaticResource AppH2}" Margin="0,24,0,4" />
                    <TextBlock Text="{loc:Translate Benchmarks_SuggestedOrder_Hint}"
                               Style="{StaticResource AppMuted}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding Hints}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DependencyHintViewModel}">
                                <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="{StaticResource RadiusSm}"
                                        Padding="14,10"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                                <Run Text="{loc:Translate Benchmarks_Hint_GroupLabel}" />
                                                <Run Text="{Binding GroupId, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Margin="0,4,0,0">
                                                <Run Text="{loc:Translate Benchmarks_Hint_CurrentLabel}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <Run Text="{Binding CurrentOrderDisplay, Mode=OneWay}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            </TextBlock>
                                            <TextBlock Margin="0,2,0,0"
                                                       Visibility="{Binding IsReorderSuggested, Converter={StaticResource BoolToVisibility}}">
                                                <Run Text="{loc:Translate Benchmarks_Hint_SuggestedLabel}" Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
                                                <Run Text="{Binding SuggestedOrderDisplay, Mode=OneWay}"
                                                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                     FontWeight="SemiBold" />
                                            </TextBlock>
                                            <ItemsControl ItemsSource="{Binding EdgeDescriptions}" Margin="0,6,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" Style="{StaticResource AppMuted}" FontSize="{StaticResource FontSizeCaption}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                        <ui:Button Grid.Column="1"
                                                   Appearance="Primary"
                                                   Content="{loc:Translate Benchmarks_Hint_ApplyButton}"
                                                   VerticalAlignment="Center"
                                                   Margin="16,0,0,0"
                                                   Command="{Binding DataContext.ApplySuggestedOrderCommand, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                   CommandParameter="{Binding}"
                                                   Visibility="{Binding IsReorderSuggested, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Group run timelines -->
                    <TextBlock Text="{loc:Translate Benchmarks_Section_GroupRuns}" Style="{StaticResource AppH2}" Margin="0,24,0,8" />
                    <ItemsControl ItemsSource="{Binding GroupRuns}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:GroupRunSummaryViewModel}">
                                <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="{StaticResource RadiusSm}"
                                        Padding="14,10"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <ctrl:GroupIconView Icon="{Binding GroupIcon}"
                                                                    IconSize="18"
                                                                    IconForeground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,0,8,0" />
                                                <TextBlock VerticalAlignment="Center">
                                                    <Run Text="{Binding GroupName, Mode=OneWay}" FontWeight="SemiBold" />
                                                    <Run Text="  " />
                                                    <Run Text="{Binding StartedDisplay, Mode=OneWay}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0" MinWidth="80">
                                                <TextBlock Text="{loc:Translate Benchmarks_Metric_Total}" Style="{StaticResource AppMuted}" FontSize="10" />
                                                <TextBlock Text="{Binding TotalDurationDisplay}" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0,0,0" MinWidth="180">
                                                <TextBlock Text="{loc:Translate Benchmarks_Metric_Bottleneck}" Style="{StaticResource AppMuted}" FontSize="10" />
                                                <TextBlock Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                                    <Run Text="{Binding BottleneckApp, Mode=OneWay}" />
                                                    <Run Text="  " />
                                                    <Run Text="{Binding BottleneckDurationDisplay, Mode=OneWay}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Bars}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:GroupRunAppBarViewModel}">
                                                    <Grid Margin="0,2,0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="150" />
                                                            <ColumnDefinition Width="60" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding AppName}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding DurationDisplay}"
                                                                   VerticalAlignment="Center"
                                                                   Style="{StaticResource AppMuted}" />
                                                        <Grid Grid.Column="2" Width="520" Height="10"
                                                              Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                                              VerticalAlignment="Center" HorizontalAlignment="Left">
                                                            <Border Margin="{Binding OffsetFraction, Converter={StaticResource FractionToLeftMargin}}"
                                                                    Width="{Binding WidthFraction, Converter={StaticResource FractionToWidth}}"
                                                                    HorizontalAlignment="Left"
                                                                    CornerRadius="2">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsReady}" Value="False">
                                                                                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Border.ToolTip>
                                                                    <ToolTip>
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding AppName}" FontWeight="SemiBold" />
                                                                            <TextBlock>
                                                                                <Run Text="{Binding DurationDisplay, Mode=OneWay}" />
                                                                                <Run Text=" · " />
                                                                                <Run Text="{Binding OutcomeDisplay, Mode=OneWay}" />
                                                                                <Run Text=" · " />
                                                                                <Run Text="{Binding SignalDisplay, Mode=OneWay}" />
                                                                            </TextBlock>
                                                                        </StackPanel>
                                                                    </ToolTip>
                                                                </Border.ToolTip>
                                                            </Border>
                                                        </Grid>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Recent launches -->
                    <TextBlock Text="{loc:Translate Benchmarks_Section_RecentLaunches}" Style="{StaticResource AppH2}" Margin="0,24,0,8" />
                    <ItemsControl ItemsSource="{Binding Recent}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:BenchmarkRowViewModel}">
                                <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="{StaticResource RadiusSm}"
                                        Padding="12,8"
                                        Margin="0,0,0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding AppName}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding WhenDisplay}"
                                                   Style="{StaticResource AppMuted}"
                                                   VerticalAlignment="Center" Margin="12,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding DurationDisplay}"
                                                   VerticalAlignment="Center" Margin="12,0" MinWidth="60"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        <Border Grid.Column="3" Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                                CornerRadius="{StaticResource RadiusXs}" Padding="6,1" Margin="4,0">
                                            <TextBlock Text="{Binding ColdWarm}" Style="{StaticResource AppMuted}" />
                                        </Border>
                                        <Border Grid.Column="4" Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                                CornerRadius="{StaticResource RadiusXs}" Padding="6,1" Margin="4,0">
                                            <TextBlock Text="{Binding SignalDisplay}" Style="{StaticResource AppMuted}" />
                                        </Border>
                                        <TextBlock Grid.Column="5" Text="{Binding OutcomeDisplay}"
                                                   Style="{StaticResource AppMuted}"
                                                   VerticalAlignment="Center" Margin="12,0,0,0" />
                                        <Border Grid.Column="5"
                                                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                                CornerRadius="{StaticResource RadiusXs}"
                                                Padding="6,1" Margin="8,0,0,0"
                                                HorizontalAlignment="Right"
                                                ToolTip="{loc:Translate Benchmarks_Regression_Tooltip}"
                                                Visibility="{Binding IsRegression, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Warning24" FontSize="12"
                                                               Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                                               VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding RegressionText}"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                                           Margin="4,0,0,0" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Detail pane: Settings view (PowerToys-inspired) -->
            <ScrollViewer Grid.Column="1"
                          Margin="{StaticResource ContentPagePadding}"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding IsSettingsView, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Margin="0,4,8,24" MaxWidth="860" HorizontalAlignment="Center">

                    <!-- Page heading -->
                    <TextBlock Text="{loc:Translate Settings_Heading}" Style="{StaticResource AppH1}" />
                    <TextBlock Text="{loc:Translate Settings_Subtitle}" Style="{StaticResource AppMuted}" Margin="0,4,0,0" />

                    <!-- Hero card: app identity + links -->
                    <Border Style="{StaticResource SettingsCard}" Padding="20,16" Margin="0,20,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="64" Height="64"
                                    CornerRadius="{StaticResource RadiusMd}"
                                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                                    VerticalAlignment="Top"
                                    Margin="0,0,16,0">
                                <ui:SymbolIcon Symbol="Rocket24" Foreground="White" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding AppName}"
                                           FontSize="{StaticResource FontSizeLarge}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <TextBlock Text="{Binding AppVersionLabel}"
                                           Style="{StaticResource AppMuted}"
                                           Margin="0,2,0,0" />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <ui:HyperlinkButton Content="{loc:Translate Settings_About_OpenGitHub}"
                                                        Command="{Binding OpenSupportUrlCommand}"
                                                        Padding="0,2" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Version & updates -->
                    <TextBlock Text="{loc:Translate Settings_Section_Updates}" Style="{StaticResource SettingsSectionHeading}" />

                    <Border Style="{StaticResource SettingsCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource SettingsCardIconHost}">
                                <ui:SymbolIcon Symbol="ArrowSync24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource IconSizeSm}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentVersionShort}" Style="{StaticResource SettingsCardLabel}" />
                                <TextBlock Text="{Binding LastCheckedText}"
                                           Style="{StaticResource SettingsCardHint}"
                                           Visibility="{Binding LastChecked, Converter={StaticResource NotNullToVisibility}}" />
                                <ui:HyperlinkButton Content="{loc:Translate Settings_Version_ReleaseNotes}"
                                                    Command="{Binding OpenReleaseNotesCommand}"
                                                    HorizontalAlignment="Left"
                                                    Padding="0,2,0,0"
                                                    FontSize="{StaticResource FontSizeMuted}" />
                            </StackPanel>
                            <ui:Button Grid.Column="2"
                                       Appearance="Secondary"
                                       Content="{loc:Translate Settings_Version_CheckNow}"
                                       Icon="{ui:SymbolIcon ArrowSync24}"
                                       Command="{Binding CheckForUpdatesCommand}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Update available banner (green accent, shown only when IsUpdateAvailable) -->
                    <Border CornerRadius="{StaticResource RadiusMd}"
                            Padding="16,14"
                            Margin="0,4,0,4"
                            BorderThickness="1"
                            Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}"
                            BorderBrush="{DynamicResource SystemFillColorSuccessBrush}"
                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibility}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0"
                                           Symbol="CheckmarkCircle24"
                                           Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                           FontSize="24"
                                           VerticalAlignment="Top"
                                           Margin="0,2,14,0" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{loc:Translate Settings_Version_UpdateAvailable}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding LatestVersionShort}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                </StackPanel>
                                <ui:Button Content="{loc:Translate Settings_Version_InstallNow}"
                                           Command="{Binding InstallUpdateCommand}"
                                           HorizontalAlignment="Left"
                                           Margin="0,10,0,0" />
                            </StackPanel>
                            <ui:HyperlinkButton Grid.Column="2"
                                                Content="{loc:Translate Settings_Version_SeeWhatsNew}"
                                                Command="{Binding OpenReleaseNotesCommand}"
                                                VerticalAlignment="Top"
                                                FontSize="{StaticResource FontSizeMuted}" />
                        </Grid>
                    </Border>

                    <!-- Appearance -->
                    <TextBlock Text="{loc:Translate Settings_Section_Appearance}" Style="{StaticResource SettingsSectionHeading}" />

                    <Border Style="{StaticResource SettingsCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource SettingsCardIconHost}">
                                <ui:SymbolIcon Symbol="PaintBrush24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource IconSizeSm}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Translate Settings_Theme_Label}" Style="{StaticResource SettingsCardLabel}" />
                                <ui:HyperlinkButton Content="{loc:Translate Settings_Theme_OpenWindowsColors}"
                                                    Command="{Binding OpenWindowsColorSettingsCommand}"
                                                    HorizontalAlignment="Left"
                                                    Padding="0,2,0,0"
                                                    FontSize="{StaticResource FontSizeMuted}" />
                            </StackPanel>
                            <ComboBox Grid.Column="2"
                                      MinWidth="180"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedItem="{Binding SelectedTheme}"
                                      DisplayMemberPath="DisplayName" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource SettingsCardIconHost}">
                                <ui:SymbolIcon Symbol="LocalLanguage24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource IconSizeSm}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Translate Settings_Language_Label}" Style="{StaticResource SettingsCardLabel}" />
                                <TextBlock Text="{loc:Translate Settings_Language_Hint}" Style="{StaticResource SettingsCardHint}" />
                                <ui:HyperlinkButton Content="{loc:Translate Settings_Language_ReportIssue}"
                                                    Command="{Binding ReportTranslationIssueCommand}"
                                                    HorizontalAlignment="Left"
                                                    Padding="0,2,0,0"
                                                    FontSize="{StaticResource FontSizeMuted}" />
                            </StackPanel>
                            <ComboBox Grid.Column="2"
                                      MinWidth="180"
                                      VerticalAlignment="Center"
                                      ItemsSource="{Binding AvailableLanguages}"
                                      SelectedItem="{Binding SelectedLanguage}"
                                      DisplayMemberPath="NativeDisplayName" />
                        </Grid>
                    </Border>

                    <!-- Administrator mode -->
                    <TextBlock Text="{loc:Translate Settings_Section_AdminMode}" Style="{StaticResource SettingsSectionHeading}" />

                    <ui:CardExpander x:Name="AdminModeCard"
                                     IsExpanded="{Binding IsAdminCardExpanded}"
                                     Margin="0,0,0,6"
                                     ContentPadding="0"
                                     Cursor="Hand">
                        <ui:CardExpander.Style>
                            <Style TargetType="ui:CardExpander" BasedOn="{StaticResource {x:Type ui:CardExpander}}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ui:CardExpander.Style>
                        <ui:CardExpander.Icon>
                            <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="{StaticResource IconSizeMd}" />
                        </ui:CardExpander.Icon>
                        <ui:CardExpander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding AdminStatusText}" Style="{StaticResource SettingsCardLabel}" />
                                    <TextBlock TextWrapping="Wrap" Style="{StaticResource SettingsCardHint}"
                                               Text="{loc:Translate Settings_AdminMode_Description}" />
                                </StackPanel>
                                <ui:Button Grid.Column="1"
                                           Appearance="Secondary"
                                           Content="{loc:Translate Settings_AdminMode_RestartAsAdmin}"
                                           Command="{Binding RestartAsAdminCommand}"
                                           IsEnabled="{Binding CanRestartAsAdmin}"
                                           VerticalAlignment="Center"
                                           Margin="14,0,8,0" />
                            </Grid>
                        </ui:CardExpander.Header>

                        <StackPanel>
                            <Grid Margin="16,12,16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,14,0">
                                    <TextBlock Text="{loc:Translate Settings_AdminMode_AlwaysRunLabel}" Style="{StaticResource SettingsCardLabel}" />
                                    <TextBlock Text="{loc:Translate Settings_AdminMode_AlwaysRunHint_NeedsAdmin}"
                                               Style="{StaticResource SettingsCardHint}"
                                               Visibility="{Binding IsRunningAsAdmin, Converter={StaticResource NotBoolToVisibility}}" />
                                    <TextBlock Text="{loc:Translate Settings_AdminMode_AlwaysRunHint_Active}"
                                               Style="{StaticResource SettingsCardHint}"
                                               Visibility="{Binding IsRunningAsAdmin, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1"
                                                 VerticalAlignment="Center"
                                                 IsChecked="{Binding AlwaysRunAsAdmin}"
                                                 IsEnabled="{Binding CanToggleAdminSettings}" />
                            </Grid>

                            <Border Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                            <Grid Margin="16,12,16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,14,0">
                                    <TextBlock Text="{loc:Translate Settings_AdminMode_WarnLabel}" Style="{StaticResource SettingsCardLabel}" />
                                    <TextBlock Text="{loc:Translate Settings_AdminMode_WarnHint}"
                                               Style="{StaticResource SettingsCardHint}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <ui:ToggleSwitch Grid.Column="1"
                                                 VerticalAlignment="Center"
                                                 IsChecked="{Binding WarnWhenElevatedAppsPresent}" />
                            </Grid>
                        </StackPanel>
                    </ui:CardExpander>

                    <!-- Behavior -->
                    <TextBlock Text="{loc:Translate Settings_Section_Behavior}" Style="{StaticResource SettingsSectionHeading}" />

                    <Border Style="{StaticResource SettingsCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource SettingsCardIconHost}">
                                <ui:SymbolIcon Symbol="Power24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource IconSizeSm}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Translate Settings_AutoStart_Label}" Style="{StaticResource SettingsCardLabel}" />
                                <TextBlock Text="{loc:Translate Settings_AutoStart_Hint}" Style="{StaticResource SettingsCardHint}" />
                                <ui:HyperlinkButton Content="{loc:Translate Settings_AutoStart_OpenTaskScheduler}"
                                                    Command="{Binding OpenTaskSchedulerCommand}"
                                                    HorizontalAlignment="Left"
                                                    Padding="0,2,0,0"
                                                    FontSize="{StaticResource FontSizeMuted}" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="2"
                                             VerticalAlignment="Center"
                                             IsChecked="{Binding AutoStartEnabled}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource SettingsCardIconHost}">
                                <ui:SymbolIcon Symbol="ArrowMinimize24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource IconSizeSm}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Translate Settings_MinimizeToTray_Label}" Style="{StaticResource SettingsCardLabel}" />
                                <TextBlock Text="{loc:Translate Settings_MinimizeToTray_Hint}" Style="{StaticResource SettingsCardHint}" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="2"
                                             VerticalAlignment="Center"
                                             IsChecked="{Binding MinimizeToTrayOnClose}" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource SettingsCardIconHost}">
                                <ui:SymbolIcon Symbol="Alert24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource IconSizeSm}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Translate Settings_Notifications_Label}" Style="{StaticResource SettingsCardLabel}" />
                                <TextBlock Text="{loc:Translate Settings_Notifications_Hint}" Style="{StaticResource SettingsCardHint}" />
                            </StackPanel>
                            <ui:ToggleSwitch Grid.Column="2"
                                             VerticalAlignment="Center"
                                             IsChecked="{Binding ShowNotifications}" />
                        </Grid>
                    </Border>

                    <!-- Diagnostics -->
                    <TextBlock Text="{loc:Translate Settings_Section_Diagnostics}" Style="{StaticResource SettingsSectionHeading}" />

                    <Border Style="{StaticResource SettingsCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource SettingsCardIconHost}">
                                <ui:SymbolIcon Symbol="Document24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource IconSizeSm}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Translate Settings_ConfigFile_Label}" Style="{StaticResource SettingsCardLabel}" />
                                <TextBlock Text="{Binding ConfigPath}" Style="{StaticResource SettingsCardHint}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <ui:Button Grid.Column="2"
                                       Appearance="Secondary"
                                       Icon="{ui:SymbolIcon FolderOpen24}"
                                       Content="{loc:Translate Tooltip_OpenConfigFolder}"
                                       Command="{Binding OpenConfigFolderCommand}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SettingsCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource SettingsCardIconHost}">
                                <ui:SymbolIcon Symbol="TextBulletListSquare24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="{StaticResource IconSizeSm}" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                                <TextBlock Text="{loc:Translate Settings_LogFolder_Label}" Style="{StaticResource SettingsCardLabel}" />
                                <TextBlock Text="{loc:Translate Settings_LogFolder_Hint}" Style="{StaticResource SettingsCardHint}" />
                            </StackPanel>
                            <ui:Button Grid.Column="2"
                                       Appearance="Secondary"
                                       Icon="{ui:SymbolIcon FolderOpen24}"
                                       Content="{loc:Translate Tooltip_OpenLogFolder}"
                                       Command="{Binding OpenLogFolderCommand}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
    </AdornerDecorator>
</ui:FluentWindow>
