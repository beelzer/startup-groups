<ui:FluentWindow x:Class="StartupGroups.App.Views.AppEntryEditorWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:conv="clr-namespace:StartupGroups.App.Converters"
                 xmlns:loc="clr-namespace:StartupGroups.App.Localization"
                 Title="{loc:Translate Window_App_Title}"
                 Width="{StaticResource WindowAppEditorWidth}"
                 SizeToContent="Height"
                 FlowDirection="{loc:FlowDirection}"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" Title="{loc:Translate Window_App_Title}" />

        <Border Grid.Row="1" Padding="{StaticResource DialogPadding}">
            <StackPanel>
                <TextBlock Text="{loc:Translate AppEditor_Heading}" Style="{StaticResource AppH2}" Margin="0,0,0,16" />

                <TextBlock Text="{loc:Translate AppEditor_Name_Label}" Style="{StaticResource AppMuted}" Margin="0,0,0,6" />
                <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />

                <TextBlock Text="{loc:Translate AppEditor_Kind_Label}" Style="{StaticResource AppMuted}" Margin="0,0,0,6" />
                <ComboBox ItemsSource="{Binding AvailableKinds}" SelectedItem="{Binding Kind}" Margin="0,0,0,14" />

                <StackPanel Visibility="{Binding IsExecutable, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{loc:Translate AppEditor_Target_Label}" Style="{StaticResource AppMuted}" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}" />
                        <ui:Button Grid.Column="1" Content="{loc:Translate Action_Browse}" Icon="{ui:SymbolIcon FolderOpen24}" Margin="8,0,0,0" Command="{Binding BrowseExecutableCommand}" />
                    </Grid>

                    <TextBlock Text="{loc:Translate AppEditor_Arguments_Label}" Style="{StaticResource AppMuted}" Margin="0,0,0,6" />
                    <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}"
                            Padding="6,4"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            MinHeight="36"
                            Margin="0,0,0,8">
                        <ItemsControl ItemsSource="{Binding ArgumentChips}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <WrapPanel Orientation="Horizontal">
                                        <ItemsPresenter />
                                        <TextBox Text="{Binding ArgumentInput, UpdateSourceTrigger=PropertyChanged}"
                                                 MinWidth="120"
                                                 Margin="2,2,2,2"
                                                 Padding="2,0"
                                                 VerticalAlignment="Center"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 FontFamily="Consolas"
                                                 FontSize="{StaticResource FontSizeMuted}">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Enter" Command="{Binding CommitArgumentInputCommand}" />
                                                <KeyBinding Key="Tab" Command="{Binding CommitArgumentInputCommand}" />
                                                <KeyBinding Key="Back" Command="{Binding RemoveLastArgumentChipCommand}" />
                                            </TextBox.InputBindings>
                                        </TextBox>
                                    </WrapPanel>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource RadiusLg}"
                                            Padding="8,2"
                                            Margin="0,2,4,2"
                                            VerticalAlignment="Center">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick" Command="{Binding BeginEditCommand}" />
                                                </StackPanel.InputBindings>
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Cursor" Value="IBeam" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text="{Binding Value}"
                                                           FontFamily="Consolas"
                                                           FontSize="{StaticResource FontSizeMuted}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                <Button Margin="6,0,0,0"
                                                        Padding="0"
                                                        Width="14" Height="14"
                                                        Cursor="Hand"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.RemoveArgumentChipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="7">
                                                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="{StaticResource FontSizeMicro}"
                                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                            <TextBox x:Name="ChipEditBox"
                                                     Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                                                     MinWidth="60"
                                                     Padding="0"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     FontFamily="Consolas"
                                                     FontSize="{StaticResource FontSizeMuted}"
                                                     VerticalAlignment="Center"
                                                     IsVisibleChanged="ChipEditBox_IsVisibleChanged"
                                                     Loaded="ChipEditBox_Loaded"
                                                     LostFocus="ChipEditBox_LostFocus">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                                <TextBox.InputBindings>
                                                    <KeyBinding Key="Enter" Command="{Binding CommitEditCommand}" />
                                                    <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}" />
                                                </TextBox.InputBindings>
                                            </TextBox>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <StackPanel Visibility="{Binding HasSuggestions, Converter={StaticResource BoolToVisibility}}" Margin="0,0,0,14">
                        <TextBlock Text="{loc:Translate AppEditor_SuggestedArguments_Label}" Style="{StaticResource AppMuted}" Margin="0,2,0,6" />
                        <ItemsControl ItemsSource="{Binding SuggestedArguments}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,6,6"
                                            Padding="10,4"
                                            Cursor="Hand"
                                            Command="{Binding DataContext.ToggleSuggestionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding Description}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="{StaticResource RadiusChip}"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter VerticalAlignment="Center" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsSelected}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                    </MultiDataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsSelected}" Value="True" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="{Binding Flag}"
                                                   FontSize="{StaticResource FontSizeMuted}"
                                                   FontFamily="Consolas"
                                                   Foreground="{Binding Path=Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock Text="{loc:Translate AppEditor_WorkingDir_Label}" Style="{StaticResource AppMuted}" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />
                        <ui:Button Grid.Column="1" Content="{loc:Translate Action_Browse}" Icon="{ui:SymbolIcon FolderOpen24}" Margin="8,0,0,0" Command="{Binding BrowseWorkingDirectoryCommand}" />
                    </Grid>
                </StackPanel>

                <StackPanel Visibility="{Binding IsService, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{loc:Translate AppEditor_Service_Label}" Style="{StaticResource AppMuted}" Margin="0,0,0,6" />
                    <ui:TextBox Text="{Binding Service, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />
                </StackPanel>

                <TextBlock Text="{loc:Translate AppEditor_Delay_Label}" Style="{StaticResource AppMuted}" Margin="0,0,0,6" />
                <ui:TextBox Text="{Binding DelayAfterSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />

                <ui:ToggleSwitch Content="{loc:Translate AppEditor_Enabled_Label}" IsChecked="{Binding Enabled}" Margin="0,0,0,22" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="{loc:Translate Action_Cancel}" Click="Cancel_Click" IsCancel="True" Margin="0,0,8,0" />
                    <ui:Button Content="{loc:Translate Action_Save}" Appearance="Primary" Click="Save_Click" IsDefault="True" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
