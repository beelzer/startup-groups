<ui:FluentWindow x:Class="StartupGroups.App.Views.RegistryRunValueEditorWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:conv="clr-namespace:StartupGroups.App.Converters"
                 xmlns:loc="clr-namespace:StartupGroups.App.Localization"
                 xmlns:vm="clr-namespace:StartupGroups.App.ViewModels"
                 Title="{loc:Translate Window_RegistryEditor_Title}"
                 Width="{StaticResource WindowAppEditorWidth}"
                 SizeToContent="Height"
                 FlowDirection="{loc:FlowDirection}"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:BoolToVisibilityConverter x:Key="NotBoolToVisibility" Invert="True" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" Title="{loc:Translate Window_RegistryEditor_Title}" />

        <Border Grid.Row="1" Padding="{StaticResource DialogPadding}">
            <StackPanel>
                <TextBlock Text="{loc:Translate RegEditor_Heading}" Style="{StaticResource AppH2}" Margin="0,0,0,16" />

                <TextBlock Text="{loc:Translate RegEditor_KeyPath_Label}" Style="{StaticResource AppMuted}" Margin="0,0,0,6" />
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}"
                            Padding="10,8">
                        <TextBlock Text="{Binding KeyPathDisplay}"
                                   FontFamily="Consolas"
                                   FontSize="{StaticResource FontSizeMuted}"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </Border>
                    <ui:Button Grid.Column="1"
                               Icon="{ui:SymbolIcon Copy24}"
                               ToolTip="{loc:Translate RegEditor_CopyKeyPath_Tooltip}"
                               Command="{Binding CopyKeyPathCommand}"
                               Margin="8,0,0,0" />
                    <ui:Button Grid.Column="2"
                               Icon="{ui:SymbolIcon Open24}"
                               ToolTip="{loc:Translate RegEditor_OpenInRegedit_Tooltip}"
                               Command="{Binding OpenInRegeditCommand}"
                               Margin="4,0,0,0" />
                </Grid>

                <TextBlock Text="{loc:Translate RegEditor_ValueName_Label}" Style="{StaticResource AppMuted}" Margin="0,0,0,6" />
                <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />

                <!-- Chip-mode editor: path on its own row + tokenized args. Used when
                     the original command parses cleanly. -->
                <StackPanel Visibility="{Binding UseRawMode, Converter={StaticResource NotBoolToVisibility}}">
                    <TextBlock Text="{loc:Translate RegEditor_Path_Label}" Style="{StaticResource AppMuted}" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                    Text="{Binding Path, UpdateSourceTrigger=PropertyChanged}"
                                    FontFamily="Consolas" />
                        <ui:Button Grid.Column="1"
                                   Content="{loc:Translate Action_Browse}"
                                   Icon="{ui:SymbolIcon FolderOpen24}"
                                   Margin="8,0,0,0"
                                   Command="{Binding BrowseExecutableCommand}" />
                    </Grid>

                    <TextBlock Text="{loc:Translate RegEditor_Arguments_Label}" Style="{StaticResource AppMuted}" Margin="0,0,0,6" />
                    <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusSm}"
                            Padding="6,4"
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            MinHeight="36"
                            Margin="0,0,0,14">
                        <ItemsControl ItemsSource="{Binding ArgumentChips}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <WrapPanel Orientation="Horizontal">
                                        <ItemsPresenter />
                                        <TextBox Text="{Binding ArgumentInput, UpdateSourceTrigger=PropertyChanged}"
                                                 MinWidth="120"
                                                 Margin="2,2,2,2"
                                                 Padding="2,0"
                                                 VerticalAlignment="Center"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 FontFamily="Consolas"
                                                 FontSize="{StaticResource FontSizeMuted}">
                                            <TextBox.InputBindings>
                                                <KeyBinding Key="Enter" Command="{Binding CommitArgumentInputCommand}" />
                                                <KeyBinding Key="Tab" Command="{Binding CommitArgumentInputCommand}" />
                                                <KeyBinding Key="Back" Command="{Binding RemoveLastArgumentChipCommand}" />
                                            </TextBox.InputBindings>
                                        </TextBox>
                                    </WrapPanel>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource RadiusLg}"
                                            Padding="8,2"
                                            Margin="0,2,4,2"
                                            VerticalAlignment="Center">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick" Command="{Binding BeginEditCommand}" />
                                                </StackPanel.InputBindings>
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Cursor" Value="IBeam" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text="{Binding Value}"
                                                           FontFamily="Consolas"
                                                           FontSize="{StaticResource FontSizeMuted}"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                <Button Margin="6,0,0,0"
                                                        Padding="0"
                                                        Width="14" Height="14"
                                                        Cursor="Hand"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        VerticalAlignment="Center"
                                                        Command="{Binding DataContext.RemoveArgumentChipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="7">
                                                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="{StaticResource FontSizeMicro}"
                                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                            <TextBox x:Name="ChipEditBox"
                                                     Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                                                     MinWidth="60"
                                                     Padding="0"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     FontFamily="Consolas"
                                                     FontSize="{StaticResource FontSizeMuted}"
                                                     VerticalAlignment="Center"
                                                     IsVisibleChanged="ChipEditBox_IsVisibleChanged"
                                                     Loaded="ChipEditBox_Loaded"
                                                     LostFocus="ChipEditBox_LostFocus">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                                <TextBox.InputBindings>
                                                    <KeyBinding Key="Enter" Command="{Binding CommitEditCommand}" />
                                                    <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}" />
                                                </TextBox.InputBindings>
                                            </TextBox>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

                <!-- Raw-mode editor: shown when the value data didn't parse cleanly into
                     path + args (unbalanced quotes, complex shells, etc.). Editing the
                     full string verbatim avoids us mangling the original on save. -->
                <StackPanel Visibility="{Binding UseRawMode, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{loc:Translate RegEditor_ValueData_Label}" Style="{StaticResource AppMuted}" Margin="0,0,0,6" />
                    <ui:TextBox Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="False"
                                FontFamily="Consolas"
                                Margin="0,0,0,6" />
                    <TextBlock Text="{loc:Translate RegEditor_RawMode_Hint}"
                               Style="{StaticResource AppMuted}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14" />
                </StackPanel>

                <TextBlock Text="{loc:Translate RegEditor_Type_Label}" Style="{StaticResource AppMuted}" Margin="0,0,0,6" />
                <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}"
                        Padding="10,8"
                        Margin="0,0,0,14">
                    <TextBlock Text="{Binding KindDisplay}"
                               FontFamily="Consolas"
                               FontSize="{StaticResource FontSizeMuted}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </Border>

                <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSm}"
                        Padding="10,8"
                        Margin="0,0,0,14"
                        Visibility="{Binding RequiresAdmin, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ShieldError24"
                                       Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                        <TextBlock Text="{loc:Translate RegEditor_RequiresAdmin_Hint}"
                                   Style="{StaticResource AppMuted}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                        CornerRadius="{StaticResource RadiusSm}"
                        Padding="10,6"
                        Margin="0,0,0,14"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ui:Button Grid.Column="0"
                               Content="{loc:Translate Action_Remove}"
                               Icon="{ui:SymbolIcon Delete24}"
                               Appearance="Danger"
                               Command="{Binding DeleteCommand}" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <ui:Button Content="{loc:Translate Action_Cancel}"
                                   Click="Cancel_Click"
                                   IsCancel="True"
                                   Margin="0,0,8,0" />
                        <ui:Button Content="{loc:Translate Action_Save}"
                                   Appearance="Primary"
                                   Command="{Binding SaveCommand}"
                                   IsDefault="True" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
