<ui:FluentWindow x:Class="StartupGroups.App.Views.AddAppPickerWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:StartupGroups.App.ViewModels"
                 xmlns:conv="clr-namespace:StartupGroups.App.Converters"
                 xmlns:loc="clr-namespace:StartupGroups.App.Localization"
                 Title="{loc:Translate Window_AddApp_Title}"
                 Width="{StaticResource WindowAddAppPickerWidth}"
                 Height="{StaticResource WindowAddAppPickerHeight}"
                 MinWidth="{StaticResource WindowAddAppPickerMinWidth}"
                 MinHeight="{StaticResource WindowAddAppPickerMinHeight}"
                 FlowDirection="{loc:FlowDirection}"
                 WindowStartupLocation="CenterOwner"
                 ShowInTaskbar="False"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibility" />
        <conv:NullToVisibilityConverter x:Key="NotNullToVisibility" Invert="True" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{loc:Translate Window_AddApp_Title}" />

        <Grid Grid.Row="1" Margin="24,8,24,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="{loc:Translate AddAppPicker_Heading}"
                           Style="{StaticResource AppH2}" />
                <TextBlock Text="{loc:Translate AddAppPicker_Subtitle}"
                           Style="{StaticResource AppMuted}"
                           TextWrapping="Wrap"
                           Margin="0,2,0,0" />
            </StackPanel>
            <ui:TextBox Grid.Row="1"
                        PlaceholderText="{loc:Translate AddAppPicker_SearchPlaceholder}"
                        Icon="{ui:SymbolIcon Search24}"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <Border Grid.Row="2"
                Margin="24,0,24,12"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMd}">
            <Grid>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <ui:ProgressRing IsIndeterminate="True" Width="36" Height="36" />
                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource AppMuted}" Margin="0,10,0,0" HorizontalAlignment="Center" />
                </StackPanel>

                <ListView ItemsSource="{Binding AppsView}"
                          SelectedItem="{Binding HighlightedApp}"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Standard"
                          VirtualizingStackPanel.ScrollUnit="Item"
                          HorizontalContentAlignment="Stretch">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="14,10" />
                            <Setter Property="Margin" Value="4,2" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="{StaticResource RadiusSm}" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:InstalledAppViewModel}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding IsChecked}"
                                          Margin="0,0,14,0" />
                                <Grid Grid.Column="1"
                                      Width="{StaticResource IconSizeLg}" Height="{StaticResource IconSizeLg}"
                                      VerticalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Apps24" FontSize="{StaticResource IconSizeSm}"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Visibility="{Binding Icon, Converter={StaticResource NullToVisibility}}" />
                                    <Image Source="{Binding Icon}"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           Visibility="{Binding Icon, Converter={StaticResource NotNullToVisibility}}" />
                                </Grid>
                                <StackPanel Grid.Column="2" Margin="12,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="{StaticResource FontSizeMedium}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Text="{Binding SubtitleText}"
                                               Style="{StaticResource AppMuted}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0">
                                        <TextBlock.ToolTip>
                                            <ToolTip MaxWidth="1400">
                                                <TextBlock Text="{Binding SubtitleText}" TextWrapping="NoWrap" />
                                            </ToolTip>
                                        </TextBlock.ToolTip>
                                    </TextBlock>
                                </StackPanel>
                                <Border Grid.Column="3"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="{StaticResource RadiusXs}"
                                        Padding="6,2">
                                    <TextBlock Text="{Binding SourceBadge}" Style="{StaticResource AppMuted}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="24,0,24,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Style="{StaticResource AppMuted}"
                       Text="{Binding CheckedCountText}" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:Button Content="{loc:Translate Action_AddBlank}"
                           Icon="{ui:SymbolIcon DocumentAdd24}"
                           Command="{Binding AddBlankCommand}"
                           MinHeight="{StaticResource ButtonMinHeight}"
                           Margin="0,0,8,0" />
                <ui:Button Content="{loc:Translate Action_EditSelected}"
                           Icon="{ui:SymbolIcon Edit24}"
                           Command="{Binding EditSelectedCommand}"
                           MinHeight="{StaticResource ButtonMinHeight}"
                           Margin="0,0,8,0" />
                <ui:Button Content="{loc:Translate Action_Cancel}"
                           Click="Cancel_Click"
                           IsCancel="True"
                           MinHeight="{StaticResource ButtonMinHeight}"
                           Margin="0,0,8,0" />
                <ui:Button Appearance="Primary"
                           Icon="{ui:SymbolIcon Add24}"
                           Content="{loc:Translate Action_AddSelected}"
                           Command="{Binding AddSelectedCommand}"
                           IsDefault="True"
                           MinHeight="{StaticResource ButtonMinHeight}" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
