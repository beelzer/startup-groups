<UserControl x:Class="StartupGroups.Installer.UI.Views.UninstallOptionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Margin="24,16,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Uninstall Startup Groups"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock Text="Pick what to keep. App files are always removed; user data is preserved by default so a future reinstall picks up where you left off."
                       FontSize="13"
                       TextWrapping="Wrap"
                       Margin="0,4,0,12"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,4,0,0">

            <Border CornerRadius="8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="14,10"
                    Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Grid.Column="0"
                                   Symbol="Settings24"
                                   FontSize="20"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Also delete settings and groups"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="%AppData%\StartupGroups (groups, preferences, channel)"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="12"
                                   Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="2"
                                     IsChecked="{Binding DeleteUserConfig, Mode=TwoWay}"
                                     VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border CornerRadius="8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="14,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:SymbolIcon Grid.Column="0"
                                   Symbol="DocumentBulletList24"
                                   FontSize="20"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Also delete logs and benchmarks"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="%LocalAppData%\StartupGroups.UserData (logs, feed cache, launch DB)"
                                   FontFamily="Cascadia Mono, Consolas, monospace"
                                   FontSize="12"
                                   Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <ui:ToggleSwitch Grid.Column="2"
                                     IsChecked="{Binding DeleteLogsAndCache, Mode=TwoWay}"
                                     VerticalAlignment="Center" />
                </Grid>
            </Border>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="1"
                       Content="Cancel"
                       Command="{Binding CancelCommand}"
                       Margin="0,0,8,0" />
            <ui:Button Grid.Column="2"
                       Content="Uninstall"
                       Appearance="Primary"
                       Icon="{ui:SymbolIcon Delete24}"
                       Command="{Binding ContinueCommand}"
                       IsDefault="True" />
        </Grid>
    </Grid>
</UserControl>
