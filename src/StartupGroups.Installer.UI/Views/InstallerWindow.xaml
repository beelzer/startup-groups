<ui:FluentWindow x:Class="StartupGroups.Installer.UI.Views.InstallerWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Startup Groups Installer"
                 Width="560"
                 Height="360"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Startup Groups Installer" />

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Width="64" Height="64"
                    CornerRadius="14"
                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                    Margin="0,0,0,20"
                    HorizontalAlignment="Center">
                <ui:SymbolIcon Symbol="Box32"
                               FontSize="36"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="Startup Groups"
                       FontSize="22"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
            <TextBlock Text="{Binding Status}"
                       FontSize="13"
                       Margin="0,8,0,0"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="32,0,32,28">
            <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                         Maximum="1"
                         Height="8"
                         IsIndeterminate="False"
                         HorizontalAlignment="Stretch" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
